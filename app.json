{
  "expo": {
    "name": "HighBallers",
    "slug": "highballers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "highballers",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.highballers.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.highballers.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B2C"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HighBallers to access your photos for profile and club images."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow HighBallers to pin your current location for game courts."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ]
  }
}
