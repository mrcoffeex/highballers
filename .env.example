# Supabase — copy from Dashboard → Project Settings → API
# Use the publishable key (sb_publishable_...), NOT the secret key (sb_secret_...)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Supabase Auth redirects (email confirmation + Google OAuth)
# Add EVERY redirect URL you use in Supabase > Auth > URL Configuration (exact match):
#   highballers://oauth-callback
#   exp://YOUR_LAN_IP:8081/--/oauth-callback      (Expo Go + npm run android:dev — default)
#   exp://127.0.0.1:8081/--/oauth-callback        (only with EXPO_ANDROID_USE_LOCALHOST=1)
# Optional: force OAuth redirect (must match Supabase allow list and Metro host)
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=exp://192.168.1.10:8081/--/oauth-callback
# EXPO_PUBLIC_OAUTH_PREFER_LOCALHOST=true
#   http://localhost:8081/oauth-callback          (web dev)
#   http://127.0.0.1:8081/oauth-callback          (if you open web via 127.0.0.1)
# Site URL in Supabase should match how you open the app (e.g. http://localhost:8081)

# Dev only: clear session on launch and show the login screen
EXPO_PUBLIC_DEV_START_AT_LOGIN=true

# Expo Go on device/simulator: avoid worklets crash from expo-router stack gestures.
# Set automatically by `npm run android:dev`; add manually for `npm run start:dev` / ios:dev.
# EXPO_PUBLIC_EXPO_GO_GESTURE_STUB=1

# Android dev networking (npm run android:dev):
# - Default: LAN IP (exp://192.168.x.x:8081) for emulator and physical device.
# - EXPO_ANDROID_USE_LOCALHOST=1 — use 127.0.0.1 + adb reverse instead.
# - EXPO_ANDROID_TUNNEL=1 or `npm run android:dev:tunnel` — if firewall blocks LAN.

# Optional: Expo access token for non-interactive CLI auth (CI / automation)
# Create at https://expo.dev/accounts/[account]/settings/access-tokens
# EXPO_TOKEN=your-expo-access-token

# Optional: public web URL for shareable club invite links (e.g. https://highballers.app)
# EXPO_PUBLIC_APP_URL=https://your-deployed-web-url.com

# All-Star subscription product ID (must match App Store Connect & Google Play Console)
# EXPO_PUBLIC_ALL_STAR_PRODUCT_ID=com.highballers.app.all_star_monthly

# GIPHY API key for in-app GIF search in club chat (free tier at developers.giphy.com)
# EXPO_PUBLIC_GIPHY_API_KEY=your-giphy-api-key
